# ============================================
# Graph Code 配置文件示例
# ============================================
# 复制此文件为 .env 并填入你的配置
# cp .env.example .env
# ============================================

# --------------------------------------------
# LLM 配置（必填）
# --------------------------------------------

# API Key - 你的 LLM 服务 API 密钥
LLM_API_KEY=sk-ibRjg7CIevHXORbQpwg1sWoUwz46TFdMzZCmMp8aAk2r3SxT

# Base URL - API 基础 URL
# Moonshot: https://api.moonshot.cn/v1
# OpenAI:   https://api.openai.com/v1（可省略）
# Azure:    https://your-resource.openai.azure.com/openai/deployments/your-deployment
LLM_BASE_URL=https://api.moonshot.cn/v1

# 模型名称
# Moonshot 推荐:
#   - moonshot-v1-8k      (8K 上下文，稳定)
#   - moonshot-v1-32k     (32K 上下文)
#   - moonshot-v1-128k    (128K 上下文)
#   - kimi-k2-turbo-preview  (性能更好)
# OpenAI 推荐:
#   - gpt-4o-mini         (性价比高)
#   - gpt-4o              (功能最强)
#   - gpt-4-turbo
LLM_MODEL=moonshot-v1-8k

# --------------------------------------------
# 可选配置
# --------------------------------------------

# 工作目录（默认：当前目录）
# WORKING_DIR=/home/user/projects/my-project

# 自动确认所有操作（默认：false）
# 设为 true 则跳过所有确认提示（谨慎使用！）
# AUTO_CONFIRM=false

# 最大工具迭代次数（默认：10）
# 防止无限循环的安全限制
# MAX_TOOL_ITERATIONS=10

# --------------------------------------------
# 配置示例
# --------------------------------------------

# --- Moonshot (Kimi) ---
# LLM_API_KEY=sk-your-moonshot-key
# LLM_BASE_URL=https://api.moonshot.cn/v1
# LLM_MODEL=moonshot-v1-8k

# --- OpenAI ---
# LLM_API_KEY=sk-your-openai-key
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o-mini

# --- Azure OpenAI ---
# LLM_API_KEY=your-azure-key
# LLM_BASE_URL=https://your-resource.openai.azure.com/openai/deployments/your-deployment
# LLM_MODEL=gpt-4

# --- 本地模型 (Ollama) ---
# LLM_API_KEY=not-needed
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_MODEL=llama3.1

# --- 本地模型 (vLLM) ---
# LLM_API_KEY=not-needed
# LLM_BASE_URL=http://localhost:8000/v1
# LLM_MODEL=meta-llama/Meta-Llama-3-8B-Instruct
